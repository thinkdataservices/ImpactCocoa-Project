{
  "name": "be",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc",
    "generate:swagger": "tsx generate-swagger.ts",
    "db:migrate": "tsx db/migrate.ts",
    "db:reset": "rm -f data.db && tsx db/migrate.ts",
    "db:pg:migrate": "tsx db/postgres/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "hono": "^4.12.9",
    "pg": "^8.20.0",
    "sql.js": "^1.14.1",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/sql.js": "^1.4.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
